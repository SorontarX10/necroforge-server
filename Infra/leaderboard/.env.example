POSTGRES_DB=leaderboard
POSTGRES_USER=leaderboard
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

LEADERBOARD_VERSION_LOCK=
LEADERBOARD_ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
LEADERBOARD_SESSION_TTL_SECONDS=300
LEADERBOARD_MAX_START_PER_MINUTE_PER_PLAYER=20
LEADERBOARD_MAX_SUBMIT_PER_MINUTE_PER_PLAYER=20
LEADERBOARD_MIN_RUN_DURATION_SECONDS=30
LEADERBOARD_MAX_SCORE_PER_MINUTE=120000
LEADERBOARD_MAX_KILLS_PER_MINUTE=3000
LEADERBOARD_MAX_PAGE_SIZE=50
LEADERBOARD_AUTH_BROKER_ENABLED=false
LEADERBOARD_AUTH_PUBLIC_BASE_URL=https://leaderboard.example.com
LEADERBOARD_AUTH_STATE_SECRET=CHANGE_ME_AUTH_STATE_SECRET
LEADERBOARD_AUTH_STATE_TTL_SECONDS=600
LEADERBOARD_AUTH_GOOGLE_ENABLED=false
LEADERBOARD_AUTH_GOOGLE_CLIENT_ID=
LEADERBOARD_AUTH_GOOGLE_CLIENT_SECRET=
LEADERBOARD_AUTH_GOOGLE_SCOPES=openid profile email
LEADERBOARD_AUTH_MICROSOFT_ENABLED=false
LEADERBOARD_AUTH_MICROSOFT_TENANT=common
LEADERBOARD_AUTH_MICROSOFT_CLIENT_ID=
LEADERBOARD_AUTH_MICROSOFT_CLIENT_SECRET=
LEADERBOARD_AUTH_MICROSOFT_SCOPES=openid profile email offline_access
LEADERBOARD_AUTH_FACEBOOK_ENABLED=false
LEADERBOARD_AUTH_FACEBOOK_CLIENT_ID=
LEADERBOARD_AUTH_FACEBOOK_CLIENT_SECRET=
LEADERBOARD_AUTH_FACEBOOK_SCOPES=public_profile,email

# Domain pointed to your Oracle VPS IP (for HTTPS cert issuance in Caddy)
LEADERBOARD_DOMAIN=leaderboard.example.com
LEADERBOARD_ADMIN_EMAIL=admin@example.com
