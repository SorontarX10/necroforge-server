POSTGRES_DB=leaderboard
POSTGRES_USER=leaderboard
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

LEADERBOARD_VERSION_LOCK=
LEADERBOARD_SESSION_TTL_SECONDS=300
LEADERBOARD_MAX_START_PER_MINUTE_PER_PLAYER=20
LEADERBOARD_MAX_SUBMIT_PER_MINUTE_PER_PLAYER=20
LEADERBOARD_MIN_RUN_DURATION_SECONDS=30
LEADERBOARD_MAX_SCORE_PER_MINUTE=120000
LEADERBOARD_MAX_KILLS_PER_MINUTE=3000
LEADERBOARD_MAX_PAGE_SIZE=50

# Domain pointed to your Oracle VPS IP (for HTTPS cert issuance in Caddy)
LEADERBOARD_DOMAIN=leaderboard.example.com
LEADERBOARD_ADMIN_EMAIL=admin@example.com
